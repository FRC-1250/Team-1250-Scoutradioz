[
    {
    "type": "importdata",
    "datafields": [
      "PIThopperLength",
      "PIThopperWidth",
      "PIThopperHeight",
      "EXTtbaAutoTowerPoints",
      "EXTtbaTotalTeleopPoints",
      "EXTtbaEndgameTowerPoints"
    ]
    },
    {
        "type": "derived",
        "formula": "PIThopperLength * PIThopperWidth * PIThopperHeight",
        "id": "estimatedVolume"
    },
    {
        "type": "derived",
        "formula": "if(estimatedVolume > 0, (estimatedVolume * 0.6) / 180, 15)",
        "id": "estimatedBallCapacity"
    },
    {
        "type": "derived",
        "formula": "(autoPayloads * estimatedBallCapacity) + (autoHalfPayloads * estimatedBallCapacity * 0.5) + (autoQuarterPayloads * estimatedBallCapacity * 0.25) + 1*autoManualFuel + EXTtbaAutoTowerPoints",
        "id": "totalAutoPoints"
    },
    {
        "type": "derived",
        "formula": "(teleopPayloads * estimatedBallCapacity) + (teleopHalfPayloads * estimatedBallCapacity * 0.5) + (teleopQuarterPayloads * estimatedBallCapacity * 0.25) + 1*teleopManualFuel - totalMinorFouls - totalMajorFouls",
        "id": "totalTeleopPoints"
    },
    {
        "type": "derived",
        "formula": "EXTtbaEndgameTowerPoints",
        "id": "totalEndgamePoints"
    },
    {
        "type": "derived",
        "formula": "totalAutoPoints + totalTeleopPoints + totalEndgamePoints",
        "id": "contributedPoints"
    },
    {
        "type": "derived",
        "formula": "(autoPayloads * estimatedBallCapacity) + (autoHalfPayloads * estimatedBallCapacity * 0.5) + (autoQuarterPayloads * estimatedBallCapacity * 0.25) + 1*autoManualFuel",
        "id": "autoFuel"
    },
    {
        "type": "derived",
        "formula": "(teleopPayloads * estimatedBallCapacity) + (teleopHalfPayloads * estimatedBallCapacity * 0.5) + (teleopQuarterPayloads * estimatedBallCapacity * 0.25) + 1*teleopManualFuel",
        "id": "teleopFuel"
    },
    {
        "type": "derived",
        "formula": "passedNZ + passedOZ",
        "id": "totalPassing"
    },
    {
        "type": "derived",
        "formula": "didDefenseNZ + didDefenseOZ",
        "id": "totalDefense"
    },
    {
        "type": "header",
        "label": "Autonomous",
        "id": "autonomouslbl"
    },
    {
    "type": "image",
    "image_id": "allianceZone"
    },
    {
        "type": "multiselect",
        "label": "Starting Position",
        "options": ["Not There", "Outpost Side", "Middle", "Depot Side"],
        "id": "startingPosition"
    },
    {
        "type": "counter",
        "label": "Quarter Payloads scored",
        "id": "autoQuarterPayloads"
    },
    {
        "type": "counter",
        "label": "Half Payloads scored",
        "id": "autoHalfPayloads"
    },
    {
        "type": "counter",
        "label": "Payloads scored",
        "id": "autoPayloads"
    },
    {
        "type": "counter",
        "label": "Manual Fuel adjustment",
        "id": "autoManualFuel"
    },
    {
        "type": "checkbox",
        "label": "Robot got Fuel from the Neutral Zone?",
        "id": "autoNZ"
    },
    {
        "type": "checkbox",
        "label": "Robot got Fuel from their Depot?",
        "id": "autoDepot"
    },
    {
        "type": "checkbox",
        "label": "Robot got Fuel from their Outpost?",
        "id": "autoOutpost"
    },
    {
        "type": "spacer"
    },
    {
        "type": "header",
        "label": "Teleoperated",
        "id": "teleoplbl"
    },
    {
        "type": "counter",
        "label": "Quarter Payloads scored",
        "id": "teleopQuarterPayloads"
    },
    {
        "type": "counter",
        "label": "Half Payloads scored",
        "id": "teleopHalfPayloads"
    },
    {
        "type": "counter",
        "label": "Payloads scored",
        "id": "teleopPayloads"
    },
    {
        "type": "counter",
        "label": "Manual Fuel adjustment",
        "id": "teleopManualFuel"
    },
    {
        "type": "checkbox",
        "label": "Robot passed fuel from the Neutral Zone?",
        "id": "passedNZ"
    },
    {
        "type": "checkbox",
        "label": "Robot passed fuel from the Opponent's Zone?",
        "id": "passedOZ"
    },
    {
        "type": "checkbox",
        "label": "Robot played defense in the Neutral Zone?",
        "id": "didDefenseNZ"
    },
    {
        "type": "checkbox",
        "label": "Robot played defense in the Opponent's Zone?",
        "id": "didDefenseOZ"
    },
    {
        "type": "counter",
        "label": "Total minor fouls",
        "id": "totalMinorFouls"
    },
    {
        "type": "counter",
        "label": "Total major fouls",
        "id": "totalMajorFouls"
    },
    {
        "type": "spacer"
    },
    {
        "type": "header",
        "label": "Endgame",
        "id": "endgameLbl"
    },
    {
        "type": "slider",
        "variant": "standard",
        "label": "How much time was on the clock when they started climbing?",
        "options": {"min": 0, "max": 30, "step": 5},
        "id": "climbingStartTime"
    },
    {
        "type": "spacer"
    },
    {
        "type": "header",
        "label": "General",
        "id": "generalLbl"
    },
    {
        "type": "checkbox",
        "label": "Died during the match (or never started)?",
        "id": "diedDuringMatch"
    },
    {
        "type": "checkbox",
        "label": "Did they get a yellow card?",
        "id": "didYellowCard"
    },
    {
        "type": "checkbox",
        "label": "Did they get a red card?",
        "id": "didRedCard"
    },
    {
        "type": "textblock",
        "label": "Other comments and notes",
        "id": "otherNotes"
    }
]